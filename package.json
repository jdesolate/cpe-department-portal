{
  "name": "cpe-department-portal",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:landing": "npm run dev --workspace=apps/landing",
    "dev:internal": "npm run dev --workspace=apps/internal",
    "build:landing": "npm run build --workspace=apps/landing",
    "build:internal": "npm run build --workspace=apps/internal",
    "lint": "npm run lint --workspaces --if-present"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
